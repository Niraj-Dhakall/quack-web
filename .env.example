# Gateway HTTP base URL (login / session endpoints)
VITE_GATEWAY_HTTP_URL=http://localhost:8080

# Gateway WebSocket URL (real-time game events)
VITE_GATEWAY_WS_URL=ws://localhost:8080/ws

# When "true", the app runs against an in-browser mock gateway so the UI is
# fully usable without a running Go backend or Unreal host. Set to "false"
# once the real gateway is available.
VITE_USE_MOCK=true
